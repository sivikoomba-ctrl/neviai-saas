generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  slug                  String   @unique
  plan                  String   @default("free")
  stripeCustomerId      String?  @map("stripe_customer_id")
  stripeSubscriptionId  String?  @map("stripe_subscription_id")
  emailQuotaMonthly     Int      @default(50) @map("email_quota_monthly")
  aiQuotaMonthly        Int      @default(20) @map("ai_quota_monthly")
  contactQuota          Int      @default(100) @map("contact_quota")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  memberships Membership[]
  contacts    Contact[]
  deals       Deal[]
  interactions Interaction[]
  emails      Email[]
  campaigns   Campaign[]
  templates   Template[]
  usages      Usage[]

  @@map("organizations")

}

model Membership {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  role      String   @default("member")
  createdAt DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("memberships")

}

model Contact {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  email     String
  phone     String?
  company   String?
  notes     String?
  tags      Json     @default("[]")
  aiSummary String?  @map("ai_summary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deals        Deal[]
  interactions Interaction[]
  emails       Email[]

  @@unique([orgId, email])
  @@map("contacts")

}

model Deal {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  title     String
  value     Decimal  @db.Decimal(12, 2)
  stage     String   @default("Lead")
  aiScore   Int?     @map("ai_score")
  aiAdvice  String?  @map("ai_advice")
  contactId String   @map("contact_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("deals")

}

model Interaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  type      String
  subject   String?
  body      String?
  metadata  Json?
  contactId String   @map("contact_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("interactions")

}

model Email {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  contactId    String?   @map("contact_id") @db.Uuid
  contactName  String    @map("contact_name")
  contactEmail String    @map("contact_email")
  subject      String
  body         String
  tone         String?
  status       String    @default("draft")
  sentAt       DateTime? @map("sent_at")
  opened       Boolean   @default(false)
  openedAt     DateTime? @map("opened_at")
  campaignId   String?   @map("campaign_id") @db.Uuid
  resendId     String?   @map("resend_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact  Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  campaign Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@map("emails")

}

model Campaign {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String
  description String?
  status      String   @default("draft")
  templateId  String?  @map("template_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  template Template?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  emails   Email[]

  @@map("campaigns")

}

model Template {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  name          String
  subject       String
  body          String
  category      String?
  variables     Json?
  isAiGenerated Boolean  @default(false) @map("is_ai_generated")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@map("templates")

}

model Usage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  month      String
  emailsSent Int      @default(0) @map("emails_sent")
  aiCalls    Int      @default(0) @map("ai_calls")
  createdAt  DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, month])
  @@map("usages")

}
